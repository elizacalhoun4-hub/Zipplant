                <small>{p.get('type', 'Plant')}</small><br>
                <p style='font-size:0.8em; margin-top:5px;'>{p.get('pitch', '')}</p>
            </div>
            """, unsafe_allow_html=True)
            
            # Check if already added
            is_added = any(g['name'] == p['name'] for g in st.session_state.garden)
            if is_added:
                st.button("✓ In Garden", key=f"added_{idx}", disabled=True)
            else:
                if st.button("Add to Garden", key=f"add_{idx}"):
                    st.session_state.garden.append(p)
                    st.toast(f"Added {p['name']}!")
                    st.rerun()

# ==================== MY GARDEN TAB ====================
with tabs[2]:
